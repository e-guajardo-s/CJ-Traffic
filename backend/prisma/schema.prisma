// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────── Identidad (mínima) ─────────────────────────
// El esquema completo de permisos (rol_modulo_permiso) se define al abordar
// Obras/Bodega en Fase 1. Por ahora alcanza para relacionar autoría.

model Rol {
  id          Int                @id @default(autoincrement())
  nombre      String             @unique
  usuariosRol UsuarioRol[]
  permisos    RolModuloPermiso[]
}

model Usuario {
  id           Int    @id @default(autoincrement())
  nombre       String
  email        String @unique
  passwordHash String

  roles UsuarioRol[]
  areas UsuarioArea[]
  avisos Aviso[] @relation("AvisoAutor")

  programacionesSubidas Programacion[]  @relation("SubidoPor")
  feedbacks             Feedback[]
  bitacora              BitacoraEntry[]

  proyectosResponsable     Proyecto[]                  @relation("ProyectoResponsable")
  proyectoPaginas          ProyectoPagina[]            @relation("ProyectoPaginaAutor")
  proyectoTareas           ProyectoTarea[]             @relation("ProyectoTareaAsignado")
  troubleshootingReportado IncidenciaTroubleshooting[] @relation("TroubleshootingAutor")

  // Proyectos generales de empresa
  proyectosEmpresaResponsable ProyectoEmpresa[] @relation("ProyectoEmpresaResponsable")
  notasEmpresa                NotaEmpresa[]     @relation("NotaEmpresaAutor")

  // Obras (Operativo)
  obrasComoSubgerente   Obra[]              @relation("ObraSubgerente")
  obrasComoCoordinador  Obra[]              @relation("ObraCoordinador")
  obraTracksResponsable ObraTrack[]         @relation("ObraTrackResponsable")
  solicitudesMaterial   SolicitudMaterial[] @relation("SolicitudMaterialAutor")
  programacionesObra    ProgramacionObra[]  @relation("ProgramacionObraAutor")
  obraBitacoras         ObraBitacora[]      @relation("ObraBitacoraAutor")
  obraSubtareaNotas     ObraSubtareaNota[]  @relation("ObraSubtareaNotaAutor")
  obraSubtareasAsignadas ObraSubtarea[]     @relation("ObraSubtareaAsignado")
  obraCoordinacionesExtra ObraCoordinadorExtra[] @relation("ObraCoordinadorExtra")
  reportesDiarios       ReporteDiario[]     @relation("ReporteDiarioAutor")
}

// ───────────────────────── RBAC (§7, §9 informe) ─────────────────────────
// Autoritativo en el backend: cada request valida nivel de acceso rol↔módulo.
// Nunca se delega al frontend (que solo refleja lo que el backend autoriza).

enum NivelAcceso {
  OCULTO
  LECTURA
  ESCRITURA
}

model Modulo {
  id     Int    @id @default(autoincrement())
  clave  String @unique // ej. "iot", "firmware"
  nombre String

  permisos RolModuloPermiso[]
}

model RolModuloPermiso {
  id       Int         @id @default(autoincrement())
  rol      Rol         @relation(fields: [rolId], references: [id])
  rolId    Int
  modulo   Modulo      @relation(fields: [moduloId], references: [id])
  moduloId Int
  nivel    NivelAcceso @default(OCULTO)

  @@unique([rolId, moduloId])
}

// Un usuario puede tener más de un rol (ej. Elías es "desarrollo" pero también
// trabaja en Mantención). Los permisos por módulo se agregan por el MÁXIMO
// nivel entre todos los roles del usuario (ver /me/permissions).
model UsuarioRol {
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId Int
  rol       Rol     @relation(fields: [rolId], references: [id], onDelete: Cascade)
  rolId     Int

  @@id([usuarioId, rolId])
}

// Área organizativa (ej. "Obras", "Mantención") — etiqueta de agrupación sin
// efecto en RBAC, usada para dirigir avisos a un grupo de trabajo.
model Area {
  id       Int           @id @default(autoincrement())
  nombre   String        @unique
  usuarios UsuarioArea[]
}

model UsuarioArea {
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId Int
  area      Area    @relation(fields: [areaId], references: [id], onDelete: Cascade)
  areaId    Int

  @@id([usuarioId, areaId])
}

// Avisos del panel de administración: banners persistentes o popups de una
// sola vez, dirigidos a todos, a un área, o a un rol específico.
model Aviso {
  id              Int       @id @default(autoincrement())
  titulo          String
  cuerpo          String
  tipo            String    @default("INFO") // INFO | MANTENCION | ADVERTENCIA | URGENTE
  presentacion    String    @default("BANNER") // BANNER | POPUP
  audienciaTipo   String    @default("TODOS") // TODOS | AREA | ROL
  audienciaRef    String? // nombre de área o de rol, cuando audienciaTipo != TODOS
  fechaProgramada DateTime? // ej. fecha de una mantención programada
  vigenteHasta    DateTime? // null = sin expiración
  activo          Boolean   @default(true)
  autor           Usuario   @relation("AvisoAutor", fields: [autorId], references: [id])
  autorId         Int
  createdAt       DateTime  @default(now())
}

// ───────────────────────── Área de Desarrollo (piloto) ─────────────────
// Directorio de cruces + Mantenedor IoT (§8 informe) y Firmware con
// control de versiones y feedback de aprobación/rechazo hacia Taller (§6).

model Cruce {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique // ej. "CRX-001"
  ubicacion   String
  controlador String // ej. "Auter A5"
  createdAt   DateTime @default(now())

  gateway           GatewayIot?
  programaciones    Programacion[]
  unidadesAsignadas UnidadInventario[]
}

enum EstadoGateway {
  ONLINE
  OFFLINE
  DEGRADADO
}

model GatewayIot {
  id                  Int           @id @default(autoincrement())
  cruce               Cruce         @relation(fields: [cruceId], references: [id])
  cruceId             Int           @unique
  modelo              String? // ej. "Teltonika TRB256" — opcional: un cruce "sin instalar" puede no tener modelo definido aún
  simApn              String? // ej. "Entel M2M" — opcional, no se administra desde la UI
  // Estado de conectividad: manual hasta integrar la API de CJ SMART Traffic (telemetría en tiempo real).
  estado              EstadoGateway @default(OFFLINE)
  ultimaSenalAt       DateTime?
  fechaInstalacion    DateTime?
  fechaDesinstalacion DateTime?
  enMantencion        Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  mantenciones MantencionGateway[]
}

// Historial de mantenciones por gateway: cada visita a terreno o intervención
// queda registrada con fecha, tipo, técnico responsable y notas.
enum TipoMantencion {
  PREVENTIVA
  CORRECTIVA
  INSTALACION
  RETIRO
  OTRA
}

model MantencionGateway {
  id        Int            @id @default(autoincrement())
  gateway   GatewayIot     @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  gatewayId Int
  fecha     DateTime
  tipo      TipoMantencion @default(PREVENTIVA)
  tecnico   String? // nombre de quien ejecutó la mantención (texto libre: puede ser externo)
  notas     String?
  createdAt DateTime       @default(now())
}

enum EstadoProgramacion {
  EN_COLA
  EN_PRUEBA
  APROBADO
  RECHAZADO
}

model Programacion {
  id            Int                @id @default(autoincrement())
  cruce         Cruce              @relation(fields: [cruceId], references: [id])
  cruceId       Int
  version       String
  archivoNombre String
  archivoUrl    String? // enlace S3 (URL firmada); se completa al integrar carga real
  estado        EstadoProgramacion @default(EN_COLA)
  subidoPor     Usuario            @relation("SubidoPor", fields: [subidoPorId], references: [id])
  subidoPorId   Int
  createdAt     DateTime           @default(now())

  feedbacks Feedback[]
}

model Feedback {
  id             Int          @id @default(autoincrement())
  programacion   Programacion @relation(fields: [programacionId], references: [id])
  programacionId Int
  autor          Usuario      @relation(fields: [autorId], references: [id])
  autorId        Int
  comentario     String
  aprobado       Boolean // true = aprobado, false = rechazado
  createdAt      DateTime     @default(now())
}

// ───────────────────────── Inventario de Desarrollo ─────────────────────
// Stock de equipos que administra Desarrollo Tecnológico. Cada item (modelo,
// ej. "Teltonika TRB256") se compone de unidades individuales con ID propio.
// Una unidad está "disponible" si cruceId es null, o "en terreno" si está
// asignada a un cruce — el mismo campo es la única fuente de verdad, así que
// al desasignar/retirar un gateway (Directorio) la unidad vuelve a disponible.

model CategoriaInventario {
  id     Int              @id @default(autoincrement())
  nombre String           @unique
  items  ItemInventario[]
}

model ItemInventario {
  id           Int                 @id @default(autoincrement())
  nombre       String // ej. "Teltonika TRB256"
  sku          String? // código SKU / referencia interna del modelo, ej. "TRB256-4G"
  categoria    CategoriaInventario @relation(fields: [categoriaId], references: [id])
  categoriaId  Int
  precio       Int? // precio unitario referencial en CLP (pesos, sin decimales)
  umbralMinimo Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  unidades       UnidadInventario[]
  itemSolicituds ItemSolicitud[]
}

model UnidadInventario {
  id              Int            @id @default(autoincrement())
  item            ItemInventario @relation(fields: [itemId], references: [id])
  itemId          Int
  codigoUnidad    String // ej. "1", "SN-00123" — identifica la unidad física dentro de su item
  cruce           Cruce?         @relation(fields: [cruceId], references: [id])
  // Un cruce puede tener varias unidades asignadas (ej. varios relés). Por eso
  // cruceId NO es único.
  cruceId         Int?
  // Ubicación física (bodega/estante) cuando la unidad NO está en un cruce.
  // Es mutuamente excluyente con cruceId: si está en terreno, ubicacionFisica es null.
  ubicacionFisica String?
  // Baja: la unidad se descompuso / se retiró de circulación. Se conserva el
  // registro con una nota justificatoria. Una unidad dada de baja no cuenta como
  // stock ni puede asignarse; al darla de baja se libera cruce y ubicación física.
  dadaDeBaja      Boolean        @default(false)
  notaBaja        String?
  createdAt       DateTime       @default(now())

  @@unique([itemId, codigoUnidad])
}

// ───────────────────────── Proyectos (Área de Desarrollo) ───────────────
// Gestión de proyectos tecnológicos/ingeniería del área: documentación tipo
// Notion (varias páginas por proyecto) + tablero Kanban de tareas (columnas fijas).

enum EstadoProyecto {
  NO_INICIADO
  EN_PROGRESO
  PAUSADO
  COMPLETADO
  CANCELADO
}

model Proyecto {
  id            Int            @id @default(autoincrement())
  nombre        String
  descripcion   String?
  estado        EstadoProyecto @default(NO_INICIADO)
  fechaInicio   DateTime?
  fechaFin      DateTime?
  responsable   Usuario?       @relation("ProyectoResponsable", fields: [responsableId], references: [id])
  responsableId Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  paginas                    ProyectoPagina[]
  tareas                     ProyectoTarea[]
  tecnologias                Tecnologia[]
  componentesStack           ComponenteStack[]
  pizarra                    Pizarra?
  incidenciasTroubleshooting IncidenciaTroubleshooting[]
}

// Pizarra de bocetos y planificación: lienzo vectorial (JSON) que el frontend
// redibuja en un canvas. Con proyectoId apunta a la pizarra de ese proyecto;
// con proyectoId null es la pizarra general de ideas del área.
model Pizarra {
  id         Int       @id @default(autoincrement())
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId Int?      @unique
  contenido  Json
  updatedAt  DateTime  @updatedAt
}

// Documentación: varias páginas de texto (markdown) por proyecto, ordenables.
model ProyectoPagina {
  id         Int      @id @default(autoincrement())
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId Int
  titulo     String
  contenido  String   @default("") // markdown
  orden      Int      @default(0)
  autor      Usuario  @relation("ProyectoPaginaAutor", fields: [autorId], references: [id])
  autorId    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Kanban: columnas fijas (mismas para todos los proyectos).
enum EstadoTarea {
  POR_HACER
  EN_PROGRESO
  EN_REVISION
  HECHO
  BLOQUEADO
}

model ProyectoTarea {
  id          Int         @id @default(autoincrement())
  proyecto    Proyecto    @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId  Int
  titulo      String
  descripcion String?
  estado      EstadoTarea @default(POR_HACER)
  fechaCambioEstado DateTime? @default(now()) // fecha en que entró a su fase/columna actual; editable manualmente
  orden       Int         @default(0) // orden dentro de su columna, para drag & drop
  asignado    Usuario?    @relation("ProyectoTareaAsignado", fields: [asignadoId], references: [id])
  asignadoId  Int?
  fechaLimite DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ───────────────────────── Auditoría (§8 informe) ─────────────────────────
// Registro inmutable de acciones sensibles: cambios de stock, aprobaciones,
// accesos a documentación restringida. Nunca se actualiza ni se borra, solo se crea.

model BitacoraEntry {
  id        Int      @id @default(autoincrement())
  autor     Usuario  @relation(fields: [autorId], references: [id])
  autorId   Int
  accion    String // ej. "gateway.actualizar"
  entidad   String // ej. "GatewayIot"
  entidadId Int
  detalle   Json // valores previos/nuevos, para trazabilidad
  createdAt DateTime @default(now())
}

model Tecnologia {
  id          Int              @id @default(autoincrement())
  nombre      String // Ej: "Botonera Peatonal Inteligente"
  descripcion String? // Ej: "Sistema de pulsador con respuesta acústica y telemetría"
  categoria   String // HARDWARE, SOFTWARE, COMUNICACIONES
  archivos    ArchivoTecnico[] // Aquí se guardan los múltiples manuales

  // Relación inversa con los proyectos que utilizan esta tecnología
  proyectos     Proyecto[]
  fechaCreacion DateTime   @default(now())
}

model ArchivoTecnico {
  id        Int    @id @default(autoincrement())
  nombre    String // Ej: "Manual de Instalación Eléctrica", "Guía de Configuración MQTT"
  url       String // Ruta del archivo
  extension String // pdf, docx, etc.

  tecnologiaId Int
  tecnologia   Tecnologia @relation(fields: [tecnologiaId], references: [id], onDelete: Cascade)

  fechaSubida DateTime @default(now())
}

model ComponenteStack {
  id       Int     @id @default(autoincrement())
  capa     String // 'HARDWARE', 'RED', 'PROCESAMIENTO', 'VISUALIZACION'
  nombre   String // Ej: "Cámara Jetson Nano", "MQTT Broker AWS", "React App"
  detalles String? // Notas breves ej: "Inferencia YOLOv3-tiny local"

  proyectoId Int
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
}

model TerminoGlosario {
  id         Int    @id @default(autoincrement())
  termino    String @unique // Ej: "MQTT", "YOLOv3", "PLC"
  definicion String // Ej: "Protocolo de mensajería en tiempo real usado para conectar los cruces con la nube."
}

model IncidenciaTroubleshooting {
  id           Int      @id @default(autoincrement())
  titulo       String // Ej: "Falla de lectura RS485 en sensor de flujo"
  tipo         String // "HARDWARE" o "SOFTWARE"
  descripcion  String // Detalles de la falla
  fechaDescripcion DateTime? // Fecha en que ocurrió/se detectó la falla (distinta de `fecha`, que es el registro del ingreso)
  accionTomada String? // Solución temporal o definitiva (opcional)
  fechaAccion  DateTime? // Fecha en que se aplicó la acción/solución
  estado       String // "ABIERTO", "EN_PROCESO", "SOLUCIONADO"
  fecha        DateTime @default(now())

  // Vinculación opcional a un proyecto
  proyectoId Int?
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)

  // Quién reportó / ingresó la falla
  autorId Int
  autor   Usuario @relation("TroubleshootingAutor", fields: [autorId], references: [id])
}

// ───────────────────────── Proyectos Generales de Empresa ───────────────
// Módulo independiente de Desarrollo. Accesible a todos los roles.

model ProyectoEmpresa {
  id            Int            @id @default(autoincrement())
  nombre        String
  descripcion   String?
  estado        EstadoProyecto @default(NO_INICIADO)
  fechaInicio   DateTime?
  fechaFin      DateTime?
  responsable   Usuario?       @relation("ProyectoEmpresaResponsable", fields: [responsableId], references: [id])
  responsableId Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tareas TareaEmpresa[]
  notas  NotaEmpresa[]
}

model TareaEmpresa {
  id                Int             @id @default(autoincrement())
  titulo            String
  completada        Boolean         @default(false)
  proyectoEmpresa   ProyectoEmpresa @relation(fields: [proyectoEmpresaId], references: [id], onDelete: Cascade)
  proyectoEmpresaId Int
  createdAt         DateTime        @default(now())
}

model NotaEmpresa {
  id                Int             @id @default(autoincrement())
  contenido         String
  autor             Usuario         @relation("NotaEmpresaAutor", fields: [autorId], references: [id])
  autorId           Int
  proyectoEmpresa   ProyectoEmpresa @relation(fields: [proyectoEmpresaId], references: [id], onDelete: Cascade)
  proyectoEmpresaId Int
  createdAt         DateTime        @default(now())
}

// ───────────────────────── OBRAS (NÚCLEO) ─────────────────────────

model Obra {
  id         Int    @id @default(autoincrement())
  codigoObra String @unique // Ej: "OBR-2024-045"
  nombre     String // Ej: "Semáforo Av. Kennedy / Manquehue"
  cliente    String
  tipoObra   String // "NUEVO_SEMAFORO", "MODIFICACION", "CCTV", etc.
  tipoObraDetalle String? // descripción libre cuando tipoObra = "OTRO"

  // Fase de alto nivel para filtros generales (Inicio, Gestión, Ejecución, Cierre)
  faseGlobal FaseObra @default(INICIO)

  // Financiero (Resuelve el dolor de Javier)
  presupuesto    Decimal?
  costoAcumulado Decimal  @default(0) // Suma calculada de Órdenes de Compra y horas

  // Relaciones Humanas
  subgerenteId  Int? // Javier
  subgerente    Usuario? @relation("ObraSubgerente", fields: [subgerenteId], references: [id])
  coordinadorId Int? // Responsable principal asignado
  coordinador   Usuario? @relation("ObraCoordinador", fields: [coordinadorId], references: [id])

  fechaInicio  DateTime?
  fechaEntrega DateTime? // Deadline contractual

  // Elementos del Proyecto
  tracks         ObraTrack[]
  bitacora       ObraBitacora[]
  solicitudes    SolicitudMaterial[]
  programaciones ProgramacionObra[]
  subcontratos   Subcontrato[]
  equipamiento   EquipamientoTerreno[]
  coordinadoresExtra ObraCoordinadorExtra[]
  reportesDiarios ReporteDiario[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Subcontrato {
  id             Int                  @id @default(autoincrement())
  obra           Obra                 @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId         Int
  especialidad   String // ej: "Obras Civiles", "Estructuras Metálicas"
  empresa        String // ej: "Constructora ABC"
  montoContrato  Decimal              @db.Decimal(12, 2) // "Total Obra" (neto) de la carátula
  numeroOc       String? // N° de Orden de Compra (carátula EEPP)
  montoAnticipo  Decimal?             @db.Decimal(12, 2) // Anticipo entregado al inicio del contrato
  devAnticipoPct Decimal              @default(0) @db.Decimal(5, 4) // ej. 0.30 → se descuenta de cada EP
  retencionPct   Decimal              @default(0) @db.Decimal(5, 4) // ej. 0.05 → se descuenta de cada EP
  ivaPct         Decimal              @default(0.19) @db.Decimal(5, 4)
  // El "plan" de un contrato siempre es 100% (se cumple el contrato completo);
  // no tiene sentido una curva planificada aparte. El avance real se ve por
  // Estado de Pago (`EstadoPago.avanceAcumuladoPct`) — este campo es solo un
  // espejo rápido del acumulado del último EP importado, para listados.
  avanceReal    Decimal              @default(0) @db.Decimal(5, 2) // Porcentaje real 0-100 (espejo del último EP)
  observaciones  String?
  estadosPago    EstadoPago[]
  partidas       PartidaPresupuesto[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

// Presupuesto oficial del subcontrato, línea a línea (hoja "Detalle EP" del
// Excel). Las filas de capítulo (ej. "2.0 INSTALACIONES...") no tienen
// unidad/cantidad/precio, solo agrupan visualmente a las partidas siguientes.
model PartidaPresupuesto {
  id             Int         @id @default(autoincrement())
  subcontrato    Subcontrato @relation(fields: [subcontratoId], references: [id], onDelete: Cascade)
  subcontratoId  Int
  orden          Int         @default(0)
  esCapitulo     Boolean     @default(false)
  itemNumero     String? // ej. "2.0" (solo en filas de capítulo)
  descripcion    String
  unidad         String?
  cantidad       Decimal?    @db.Decimal(12, 2)
  precioUnitario Decimal?    @db.Decimal(12, 2)
  total          Decimal?    @db.Decimal(12, 2)

  avances AvancePartidaEP[]
}

model EstadoPago {
  id                 Int         @id @default(autoincrement())
  subcontrato        Subcontrato @relation(fields: [subcontratoId], references: [id], onDelete: Cascade)
  subcontratoId      Int
  numeroEp           String // ej: "EP-003"
  fechaEp            DateTime
  emisor             String? // quien emite el EP (carátula EEPP)
  // Carátula financiera del EP. `montoEp` se mantiene como el monto genérico
  // (compatibilidad con EP creados sin detalle de carátula); cuando hay
  // detalle, `totalPagar` es el monto real que se suma al costoAcumulado.
  montoEp            Decimal     @db.Decimal(12, 2)
  subtotal           Decimal?    @db.Decimal(12, 2) // Bruto del período, antes de descuentos
  devAnticipo        Decimal?    @db.Decimal(12, 2) // Descuento por devolución de anticipo (negativo)
  retencion          Decimal?    @db.Decimal(12, 2) // Descuento por retención (negativo)
  montoNeto          Decimal?    @db.Decimal(12, 2) // subtotal + devAnticipo + retencion (sin IVA)
  iva                Decimal?    @db.Decimal(12, 2)
  totalPagar         Decimal?    @db.Decimal(12, 2) // montoNeto + iva — lo que efectivamente se paga
  avanceAcumuladoPct Decimal?    @db.Decimal(6, 4) // % ejecutado acumulado a la fecha de este EP
  estado             String // "APROBADO", "EN REVISIÓN", "PAGADO", "PENDIENTE", "SIN INICIO"
  observaciones      String?
  archivoUrl         String? // Excel original del EP, si se importó o se adjuntó
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  avancesPartida AvancePartidaEP[]
}

// Avance de cada partida del presupuesto en un EP específico (hoja "Detalle
// EP": columnas Avance % y Avance $ — Acumulado/Anterior/Actual).
model AvancePartidaEP {
  id                 Int                @id @default(autoincrement())
  estadoPago         EstadoPago         @relation(fields: [estadoPagoId], references: [id], onDelete: Cascade)
  estadoPagoId       Int
  partida            PartidaPresupuesto @relation(fields: [partidaId], references: [id], onDelete: Cascade)
  partidaId          Int
  avanceAcumuladoPct Decimal            @default(0) @db.Decimal(6, 4)
  avanceAnteriorPct  Decimal            @default(0) @db.Decimal(6, 4)
  avanceActualPct    Decimal            @default(0) @db.Decimal(6, 4)
  montoAcumulado     Decimal            @default(0) @db.Decimal(12, 2)
  montoAnterior      Decimal            @default(0) @db.Decimal(12, 2)
  montoActual        Decimal            @default(0) @db.Decimal(12, 2)

  @@unique([estadoPagoId, partidaId])
}

enum FaseObra {
  INICIO
  GESTION
  EJECUCION
  CERRADO
}

// ───────────────────────── STATE MACHINE (TRACKS) ─────────────────────────

// Cada track es una instancia viva de un proceso dentro de la obra.
model ObraTrack {
  id                  Int       @id @default(autoincrement())
  obraId              Int
  tipo                TipoTrack // PERMISOS, ADQUISICIONES, PROGRAMACION, INSTALACION
  nombre              String? // nombre libre cuando tipo = OTRO (línea de trabajo personalizada)
  estadoActual        String // El estado específico del track (ej. "EN_TRAMITE")
  responsableId       Int? // Quién tiene la "pelota" ahora mismo en este track
  ultimaActualizacion DateTime  @default(now())

  obra        Obra           @relation(fields: [obraId], references: [id], onDelete: Cascade)
  responsable Usuario?       @relation("ObraTrackResponsable", fields: [responsableId], references: [id])
  subtareas   ObraSubtarea[]
}

// Subtareas del track, organizadas como kanban (mismas columnas que ProyectoTarea).
// Documentan los subprocesos del wireframe (ej. permisos: preparar expediente,
// ingresar, respuesta, aprobado) para que cualquiera retome el track.
model ObraSubtarea {
  id               Int               @id @default(autoincrement())
  track            ObraTrack         @relation(fields: [trackId], references: [id], onDelete: Cascade)
  trackId          Int
  titulo           String
  tipo             String? // Ej. TECNICA, ADMINISTRATIVA, TERRENO, REUNION, COMPRA
  prioridad        PrioridadSubtarea @default(MEDIA)
  fechaInicio      DateTime?
  fechaVencimiento DateTime?
  estado           EstadoTarea       @default(POR_HACER)
  orden            Int               @default(0) // orden dentro de su columna
  notas            String? // observaciones / notas de la subtarea (texto libre)
  asignado         Usuario?          @relation("ObraSubtareaAsignado", fields: [asignadoId], references: [id])
  asignadoId       Int?
  fechaEstimadaDesbloqueo DateTime? // solo relevante cuando estado = BLOQUEADO
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  archivos      ObraSubtareaArchivo[]
  observaciones ObraSubtareaNota[]
}

enum PrioridadSubtarea {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

model ObraSubtareaNota {
  id         Int          @id @default(autoincrement())
  subtarea   ObraSubtarea @relation(fields: [subtareaId], references: [id], onDelete: Cascade)
  subtareaId Int
  autor      Usuario      @relation("ObraSubtareaNotaAutor", fields: [autorId], references: [id])
  autorId    Int
  contenido  String
  createdAt  DateTime     @default(now())
}

// Documentación adjunta a una subtarea del kanban (planos, cotizaciones, fotos…).
model ObraSubtareaArchivo {
  id         Int          @id @default(autoincrement())
  subtarea   ObraSubtarea @relation(fields: [subtareaId], references: [id], onDelete: Cascade)
  subtareaId Int
  nombre     String
  url        String
  extension  String
  createdAt  DateTime     @default(now())
}

enum TipoTrack {
  PERMISOS
  ADQUISICIONES
  PROGRAMACION
  INSTALACION
  COMUNICACIONES
  ENLACES
  EMPALMES
  HITOS_UOCT
  SINTONIA_FINA
  TRASPASOS_MANTENCION
  CANALIZACION
  OBRAS_CIVILES
  OTRO
}

// ───────────────────────── LOGÍSTICA & BODEGA ─────────────────────────
// Resuelve el dolor de Bodega y los costos de Javier.

model SolicitudMaterial {
  id            Int       @id @default(autoincrement())
  obraId        Int
  solicitanteId Int // Coordinador que pide
  estado        EstadoSol // SOLICITADO, COTIZANDO, ORDEN_COMPRA, RECIBIDO, DESPACHADO
  costoTotal    Decimal? // Se llena al emitir OC. Suma al "costoAcumulado" de la Obra.
  fechaCreacion DateTime  @default(now())

  items       ItemSolicitud[]
  obra        Obra            @relation(fields: [obraId], references: [id], onDelete: Cascade)
  solicitante Usuario         @relation("SolicitudMaterialAutor", fields: [solicitanteId], references: [id])
}

enum EstadoSol {
  SOLICITADO
  COTIZANDO
  ORDEN_COMPRA
  RECIBIDO
  DESPACHADO
}

model ItemSolicitud {
  id             Int      @id @default(autoincrement())
  solicitudId    Int
  articuloDesc   String // Texto libre si no existe en inventario
  itemId         Int? // Si está en el inventario actual (ERP/Defontana sync)
  cantidad       Int
  precioUnitario Decimal? // Llenado por Bodega/Finanzas

  solicitud      SolicitudMaterial @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  itemInventario ItemInventario?   @relation(fields: [itemId], references: [id])
}

// ───────────────────────── TÉCNICA & TERRENO ─────────────────────────
// Resuelve dolores de Supervisora (Programaciones) y Técnicos (Equipamiento en terreno)

model ProgramacionObra {
  id               Int      @id @default(autoincrement())
  obraId           Int
  programadorId    Int // Supervisora / Técnico
  version          Int      @default(1)
  archivoConfigUrl String? // Link S3 al archivo real
  estado           String // EN_DESARROLLO, REVISION, APROBADO
  notasFeedback    String? // Feedback asíncrono digital
  createdAt        DateTime @default(now())

  obra        Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  programador Usuario @relation("ProgramacionObraAutor", fields: [programadorId], references: [id])
}

// Documenta exactamente qué fierros quedaron instalados en el cruce.
model EquipamientoTerreno {
  id               Int      @id @default(autoincrement())
  obraId           Int
  categoria        String // "CONTROLADOR", "CCTV", "UPS"
  modeloExacto     String // Ej: "Auter A5 - 16 Grupos"
  numeroSerie      String?
  notasInstalacion String?
  createdAt        DateTime @default(now())

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

// ───────────────────────── COMUNICACIÓN CENTRAL ─────────────────────────
// Resuelve el problema de "traspasar el estado" entre Coordinadores.

model ObraBitacora {
  id         Int      @id @default(autoincrement())
  obraId     Int
  autorId    Int
  tipoEvento String // "CAMBIO_ESTADO", "COMENTARIO", "ALERTA"
  mensaje    String
  createdAt  DateTime @default(now())

  obra  Obra    @relation(fields: [obraId], references: [id], onDelete: Cascade)
  autor Usuario @relation("ObraBitacoraAutor", fields: [autorId], references: [id])
}

// Coordinador adicional de una obra: transferencia TEMPORAL (releva al
// coordinador principal por un período) o PARALELO (comparten la gestión).
// Mientras esté `activo` y no haya vencido `vigenteHasta`, el coordinador
// extra tiene los mismos permisos de gestión sobre TODOS los tracks de la
// obra que el coordinador principal (ver coordinadoresEfectivos() en obras.ts).
model ObraCoordinadorExtra {
  id            Int       @id @default(autoincrement())
  obra          Obra      @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId        Int
  coordinador   Usuario   @relation("ObraCoordinadorExtra", fields: [coordinadorId], references: [id])
  coordinadorId Int
  tipo          String // "TEMPORAL" | "PARALELO"
  vigenteHasta  DateTime? // null = sin término definido
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now())
}

// Parte diario de terreno: registro ágil (no texto libre extenso) que
// completan los trabajadores para dejar constancia de la jornada. Distinto
// de ObraBitacora (eventos del sistema) y de ObraSubtareaNota (hilo de
// comentarios de una subtarea puntual) — este es el reporte operativo diario
// que pidió el subgerente, pensado para exportar a PDF.
model ReporteDiario {
  id               Int      @id @default(autoincrement())
  obra             Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  obraId           Int
  autor            Usuario  @relation("ReporteDiarioAutor", fields: [autorId], references: [id])
  autorId          Int
  fecha            DateTime @default(now()) // día que reporta (no necesariamente "hoy")
  trackId          Int? // línea de trabajo asociada, opcional
  personal         Int? // nº de personas en terreno
  clima            String? // "DESPEJADO" | "NUBLADO" | "LLUVIA" | "VIENTO"
  horasTrabajadas  Decimal? @db.Decimal(5, 2)
  trabajoRealizado String // resumen breve y obligatorio
  materiales       String?
  observaciones    String?
  createdAt        DateTime @default(now())
}
