// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────── Identidad (mínima) ─────────────────────────
// El esquema completo de permisos (rol_modulo_permiso) se define al abordar
// Obras/Bodega en Fase 1. Por ahora alcanza para relacionar autoría.

model Rol {
  id       Int                @id @default(autoincrement())
  nombre   String             @unique
  usuarios Usuario[]
  permisos RolModuloPermiso[]
}

model Usuario {
  id           Int    @id @default(autoincrement())
  nombre       String
  email        String @unique
  passwordHash String
  rol          Rol    @relation(fields: [rolId], references: [id])
  rolId        Int

  programacionesSubidas Programacion[] @relation("SubidoPor")
  feedbacks             Feedback[]
  bitacora              BitacoraEntry[]

  proyectosResponsable Proyecto[]       @relation("ProyectoResponsable")
  proyectoPaginas      ProyectoPagina[] @relation("ProyectoPaginaAutor")
  proyectoTareas       ProyectoTarea[]  @relation("ProyectoTareaAsignado")
}

// ───────────────────────── RBAC (§7, §9 informe) ─────────────────────────
// Autoritativo en el backend: cada request valida nivel de acceso rol↔módulo.
// Nunca se delega al frontend (que solo refleja lo que el backend autoriza).

enum NivelAcceso {
  OCULTO
  LECTURA
  ESCRITURA
}

model Modulo {
  id     Int    @id @default(autoincrement())
  clave  String @unique // ej. "iot", "firmware"
  nombre String

  permisos RolModuloPermiso[]
}

model RolModuloPermiso {
  id       Int         @id @default(autoincrement())
  rol      Rol         @relation(fields: [rolId], references: [id])
  rolId    Int
  modulo   Modulo      @relation(fields: [moduloId], references: [id])
  moduloId Int
  nivel    NivelAcceso @default(OCULTO)

  @@unique([rolId, moduloId])
}

// ───────────────────────── Área de Desarrollo (piloto) ─────────────────
// Directorio de cruces + Mantenedor IoT (§8 informe) y Firmware con
// control de versiones y feedback de aprobación/rechazo hacia Taller (§6).

model Cruce {
  id          Int      @id @default(autoincrement())
  codigo      String   @unique // ej. "CRX-001"
  ubicacion   String
  controlador String // ej. "Auter A5"
  createdAt   DateTime @default(now())

  gateway            GatewayIot?
  programaciones     Programacion[]
  unidadesAsignadas  UnidadInventario[]
}

enum EstadoGateway {
  ONLINE
  OFFLINE
  DEGRADADO
}

model GatewayIot {
  id                  Int           @id @default(autoincrement())
  cruce               Cruce         @relation(fields: [cruceId], references: [id])
  cruceId             Int           @unique
  modelo              String? // ej. "Teltonika TRB256" — opcional: un cruce "sin instalar" puede no tener modelo definido aún
  simApn              String? // ej. "Entel M2M" — opcional, no se administra desde la UI
  // Estado de conectividad: manual hasta integrar la API de CJ SMART Traffic (telemetría en tiempo real).
  estado              EstadoGateway @default(OFFLINE)
  ultimaSenalAt       DateTime?
  fechaInstalacion    DateTime?
  fechaDesinstalacion DateTime?
  enMantencion        Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  mantenciones MantencionGateway[]
}

// Historial de mantenciones por gateway: cada visita a terreno o intervención
// queda registrada con fecha, tipo, técnico responsable y notas.
enum TipoMantencion {
  PREVENTIVA
  CORRECTIVA
  INSTALACION
  RETIRO
  OTRA
}

model MantencionGateway {
  id        Int            @id @default(autoincrement())
  gateway   GatewayIot     @relation(fields: [gatewayId], references: [id], onDelete: Cascade)
  gatewayId Int
  fecha     DateTime
  tipo      TipoMantencion @default(PREVENTIVA)
  tecnico   String? // nombre de quien ejecutó la mantención (texto libre: puede ser externo)
  notas     String?
  createdAt DateTime       @default(now())
}

enum EstadoProgramacion {
  EN_COLA
  EN_PRUEBA
  APROBADO
  RECHAZADO
}

model Programacion {
  id            Int                @id @default(autoincrement())
  cruce         Cruce              @relation(fields: [cruceId], references: [id])
  cruceId       Int
  version       String
  archivoNombre String
  archivoUrl    String? // enlace S3 (URL firmada); se completa al integrar carga real
  estado        EstadoProgramacion @default(EN_COLA)
  subidoPor     Usuario            @relation("SubidoPor", fields: [subidoPorId], references: [id])
  subidoPorId   Int
  createdAt     DateTime           @default(now())

  feedbacks Feedback[]
}

model Feedback {
  id             Int          @id @default(autoincrement())
  programacion   Programacion @relation(fields: [programacionId], references: [id])
  programacionId Int
  autor          Usuario      @relation(fields: [autorId], references: [id])
  autorId        Int
  comentario     String
  aprobado       Boolean // true = aprobado, false = rechazado
  createdAt      DateTime     @default(now())
}

// ───────────────────────── Inventario de Desarrollo ─────────────────────
// Stock de equipos que administra Desarrollo Tecnológico. Cada item (modelo,
// ej. "Teltonika TRB256") se compone de unidades individuales con ID propio.
// Una unidad está "disponible" si cruceId es null, o "en terreno" si está
// asignada a un cruce — el mismo campo es la única fuente de verdad, así que
// al desasignar/retirar un gateway (Directorio) la unidad vuelve a disponible.

model CategoriaInventario {
  id     Int              @id @default(autoincrement())
  nombre String           @unique
  items  ItemInventario[]
}

model ItemInventario {
  id           Int                 @id @default(autoincrement())
  nombre       String // ej. "Teltonika TRB256"
  sku          String? // código SKU / referencia interna del modelo, ej. "TRB256-4G"
  categoria    CategoriaInventario @relation(fields: [categoriaId], references: [id])
  categoriaId  Int
  precio       Int? // precio unitario referencial en CLP (pesos, sin decimales)
  umbralMinimo Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  unidades UnidadInventario[]
}

model UnidadInventario {
  id           Int            @id @default(autoincrement())
  item         ItemInventario @relation(fields: [itemId], references: [id])
  itemId       Int
  codigoUnidad String // ej. "1", "SN-00123" — identifica la unidad física dentro de su item
  cruce        Cruce?         @relation(fields: [cruceId], references: [id])
  // Un cruce puede tener varias unidades asignadas (ej. varios relés). Por eso
  // cruceId NO es único.
  cruceId      Int?
  // Ubicación física (bodega/estante) cuando la unidad NO está en un cruce.
  // Es mutuamente excluyente con cruceId: si está en terreno, ubicacionFisica es null.
  ubicacionFisica String?
  // Baja: la unidad se descompuso / se retiró de circulación. Se conserva el
  // registro con una nota justificatoria. Una unidad dada de baja no cuenta como
  // stock ni puede asignarse; al darla de baja se libera cruce y ubicación física.
  dadaDeBaja   Boolean        @default(false)
  notaBaja     String?
  createdAt    DateTime       @default(now())

  @@unique([itemId, codigoUnidad])
}

// ───────────────────────── Proyectos (Área de Desarrollo) ───────────────
// Gestión de proyectos tecnológicos/ingeniería del área: documentación tipo
// Notion (varias páginas por proyecto) + tablero Kanban de tareas (columnas fijas).

enum EstadoProyecto {
  NO_INICIADO
  EN_PROGRESO
  PAUSADO
  COMPLETADO
  CANCELADO
}

model Proyecto {
  id            Int            @id @default(autoincrement())
  nombre        String
  descripcion   String?
  estado        EstadoProyecto @default(NO_INICIADO)
  fechaInicio   DateTime?
  fechaFin      DateTime?
  responsable   Usuario?       @relation("ProyectoResponsable", fields: [responsableId], references: [id])
  responsableId Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  paginas ProyectoPagina[]
  tareas  ProyectoTarea[]
  tecnologias Tecnologia[]
  componentesStack ComponenteStack[]
  pizarra Pizarra?
}

// Pizarra de bocetos y planificación: lienzo vectorial (JSON) que el frontend
// redibuja en un canvas. Con proyectoId apunta a la pizarra de ese proyecto;
// con proyectoId null es la pizarra general de ideas del área.
model Pizarra {
  id         Int       @id @default(autoincrement())
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId Int?      @unique
  contenido  Json
  updatedAt  DateTime  @updatedAt
}

// Documentación: varias páginas de texto (markdown) por proyecto, ordenables.
model ProyectoPagina {
  id         Int      @id @default(autoincrement())
  proyecto   Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId Int
  titulo     String
  contenido  String   @default("") // markdown
  orden      Int      @default(0)
  autor      Usuario  @relation("ProyectoPaginaAutor", fields: [autorId], references: [id])
  autorId    Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Kanban: columnas fijas (mismas para todos los proyectos).
enum EstadoTarea {
  POR_HACER
  EN_PROGRESO
  EN_REVISION
  HECHO
}

model ProyectoTarea {
  id          Int         @id @default(autoincrement())
  proyecto    Proyecto    @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  proyectoId  Int
  titulo      String
  descripcion String?
  estado      EstadoTarea @default(POR_HACER)
  orden       Int         @default(0) // orden dentro de su columna, para drag & drop
  asignado    Usuario?    @relation("ProyectoTareaAsignado", fields: [asignadoId], references: [id])
  asignadoId  Int?
  fechaLimite DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// ───────────────────────── Auditoría (§8 informe) ─────────────────────────
// Registro inmutable de acciones sensibles: cambios de stock, aprobaciones,
// accesos a documentación restringida. Nunca se actualiza ni se borra, solo se crea.

model BitacoraEntry {
  id        Int      @id @default(autoincrement())
  autor     Usuario  @relation(fields: [autorId], references: [id])
  autorId   Int
  accion    String // ej. "gateway.actualizar"
  entidad   String // ej. "GatewayIot"
  entidadId Int
  detalle   Json // valores previos/nuevos, para trazabilidad
  createdAt DateTime @default(now())
}

model Tecnologia {
  id            Int              @id @default(autoincrement())
  nombre        String           // Ej: "Botonera Peatonal Inteligente"
  descripcion   String?          // Ej: "Sistema de pulsador con respuesta acústica y telemetría"
  categoria     String           // HARDWARE, SOFTWARE, COMUNICACIONES
  archivos      ArchivoTecnico[] // Aquí se guardan los múltiples manuales
  
  // Relación inversa con los proyectos que utilizan esta tecnología
  proyectos     Proyecto[]       
  fechaCreacion DateTime         @default(now())
}

model ArchivoTecnico {
  id           Int        @id @default(autoincrement())
  nombre       String     // Ej: "Manual de Instalación Eléctrica", "Guía de Configuración MQTT"
  url          String     // Ruta del archivo
  extension    String     // pdf, docx, etc.
  
  tecnologiaId Int
  tecnologia   Tecnologia @relation(fields: [tecnologiaId], references: [id], onDelete: Cascade)
  
  fechaSubida  DateTime   @default(now())
}

model ComponenteStack {
  id          Int      @id @default(autoincrement())
  capa        String   // 'HARDWARE', 'RED', 'PROCESAMIENTO', 'VISUALIZACION'
  nombre      String   // Ej: "Cámara Jetson Nano", "MQTT Broker AWS", "React App"
  detalles    String?  // Notas breves ej: "Inferencia YOLOv3-tiny local"
  
  proyectoId  Int
  proyecto    Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
}

model TerminoGlosario {
  id         Int      @id @default(autoincrement())
  termino    String   @unique // Ej: "MQTT", "YOLOv3", "PLC"
  definicion String   // Ej: "Protocolo de mensajería en tiempo real usado para conectar los cruces con la nube."
}
